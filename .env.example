# Example environment variable overrides
# Copy to .env and customize

# Llama.cpp configuration
# LLAMA__BASE_URL=http://gpu-server:8080
# LLAMA__EMBEDDING_DIM=768
# LLAMA__BATCH_SIZE=64
# LLAMA__TIMEOUT=180

# Qdrant configuration
# QDRANT__HOST=qdrant-server
# QDRANT__PORT=6333

# Retrieval configuration
# RETRIEVAL__TOP_K=30
# RETRIEVAL__TOP_X=10
# RETRIEVAL__RELEVANCE_THRESHOLD=0.75

# Logging configuration
# LOGGING__LEVEL=DEBUG
