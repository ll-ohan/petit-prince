# === LLM ===
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=mistral-nemo:latest
LLM_API_KEY=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

AUTO_DEVICE_DETECTION=true
DEVICE_PREFERENCE=auto
DEVICE_FALLBACK_ORDER=cuda,mps,cpu
FORCE_DEVICE=

# === ORCHESTRATEUR ===
MAX_TOOL_ITERATIONS=8
ORCHESTRATOR_PORT=8000

# === MCP ===
MCP_SERVER_URL=http://mcp_server:8001
MCP_SSE_ENDPOINT=/sse

# === QDRANT ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=petit_prince

# === EMBEDDINGS ===
HF_TOKEN=
SPLADE_MODEL=naver/splade-v3
SPLADE_DEVICE=cpu
SPLADE_WEIGHT_THRESHOLD=0.005
EMBEDDINGS_DEVICE_AUTO=true
EMBEDDINGS_DEVICE=auto

# === WEB SEARCH ===
SEARCH_ENGINE_URL=http://searxng:8080
ALLOWED_DOMAINS=www.monpetitprince.fr,fr.wikipedia.org

# === FRONTEND ===
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000